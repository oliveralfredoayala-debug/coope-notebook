rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function activityPath(activityId) {
      return /databases/$(database)/documents/activities/$(activityId);
    }

    function isOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /diagnostics/{uid} {
      allow create, update: if signedIn() && uid == request.auth.uid;
      allow read, delete: if false;
    }

    match /presentations/{presentationId} {
      allow read: if signedIn();

      allow create, update: if signedIn()
        && request.resource.data.topicId is string
        && request.resource.data.slides is list
        && request.resource.data.slides.size() >= 1
        && request.resource.data.slides.size() <= 80;

      allow delete: if false;
    }

    match /activities/{activityId} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == "active"
        && request.resource.data.question is string
        && request.resource.data.options is list
        && request.resource.data.responseMode in ["single", "multi", "text", "scale"]
        && request.resource.data.accessHash is string
        && request.resource.data.hasAccessKey is bool
        && (
          (
            request.resource.data.responseMode in ["single", "multi"]
            && request.resource.data.options.size() >= 2
            && request.resource.data.options.size() <= 10
          )
          || (
            request.resource.data.responseMode == "text"
            && request.resource.data.options.size() == 0
          )
          || (
            request.resource.data.responseMode == "scale"
            && request.resource.data.options.size() == 10
          )
        );

      allow read: if signedIn()
        && resource.data.status in ["active", "closed"];

      allow update: if isOwner()
        && request.resource.data.ownerUid == resource.data.ownerUid;

      allow delete: if isOwner();

      match /responses/{responseId} {
        allow create, update: if signedIn()
          && exists(activityPath(activityId))
          && get(activityPath(activityId)).data.status == "active"
          && request.resource.data.participantUid == request.auth.uid
          && request.resource.data.questionId is string
          && request.resource.data.answers is list
          && request.resource.data.answers.size() >= 1
          && request.resource.data.answers.size() <= 10;

        allow read: if signedIn()
          && exists(activityPath(activityId))
          && get(activityPath(activityId)).data.status in ["active", "closed"];

        allow delete: if false;
      }
    }
  }
}
